DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
SECRET_KEY=replace-with-a-strong-random-secret
# Leave blank to disable public admin setup. Set temporarily only when you need a protected bootstrap flow.
ADMIN_SETUP_ACCESS_CODE=
RESEND_API_KEY=replace-with-your-resend-api-key
QUOTE_NOTIFICATION_EMAIL=felixconsult@myyahoo.com
SUPPORT_NOTIFICATION_EMAIL=felixconsult@myyahoo.com
RESEND_FROM_EMAIL=Felix Platform Quotes <quotes@felixplatforms.com>
# Optional store-specific overrides, for example:
# ADRIAN_STORE_QUOTE_FROM_EMAIL="Adrian's Styled Collection Quotes <quotes@shopwithadrian.com>"
# ADRIAN_STORE_QUOTE_NOTIFICATION_EMAIL=order@shopwithadrian.com,adrianfelix0928@gmail.com
# ADRIAN_STORE_SUPPORT_NOTIFICATION_EMAIL=order@shopwithadrian.com,adrianfelix0928@gmail.com
# WACI_RESEND_API_KEY=replace-with-your-waci-resend-api-key
# WACI_RESEND_FROM_EMAIL="Wildlife of Africa Conservation Initiative <hello@wildlifeafrica.org>"
# WACI_SUPPORT_NOTIFICATION_EMAIL=hello@wildlifeafrica.org,wildlifeaboutafrica@gmail.com
# WACI_APP_BASE_URL=https://wildlifeafrica.org
# Optional permanent product-image storage. The prefixed values are checked first, then the shared CLOUDINARY_* values if you use one account platform-wide.
PRODUCTS_CLOUDINARY_CLOUD_NAME=
PRODUCTS_CLOUDINARY_API_KEY=
PRODUCTS_CLOUDINARY_API_SECRET=
PRODUCTS_CLOUDINARY_FOLDER=felix-platform/products
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ALLOWED_ORIGINS=https://admin.felixplatforms.com,https://storeapp.felixplatforms.com,https://laundryapp.felixplatforms.com,https://your-formatter-subdomain.felixplatforms.com,https://your-admin-dashboard.vercel.app,https://your-preview-domain.vercel.app,http://localhost:8081,http://localhost:8084,http://localhost:19006
NODE_ENV=production
PORT=5000
