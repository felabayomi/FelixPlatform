# Local runtime settings for the A&F Laundry scheduler web app
PORT=5000
APP_BASE_URL=http://localhost:5000

# Production / custom domain settings
AFLAUNDRY_APP_BASE_URL=https://aflaundry.com

# Use these A&F-specific email values so this app stays separate from the main Felix Platform Resend account
AFLAUNDRY_RESEND_API_KEY=
AFLAUNDRY_RESEND_FROM_EMAIL="A & F Laundry <hello@aflaundry.com>"
AFLAUNDRY_NOTIFICATION_EMAIL=aflaundryservice@gmail.com

# Backwards-compatible fallbacks (optional)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Required in production for persistent Neon-backed appointments storage
# You can use the same shared Felix Platform Neon connection string here.
DATABASE_URL=
