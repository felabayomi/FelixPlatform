{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "redirects": [
        {
            "source": "/felix-store/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "felixplatforms.com"
                }
            ],
            "destination": "https://felixstore.felixplatforms.com/:path*",
            "permanent": true
        },
        {
            "source": "/felix-store/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "www.felixplatforms.com"
                }
            ],
            "destination": "https://felixstore.felixplatforms.com/:path*",
            "permanent": true
        },
        {
            "source": "/aflaundry/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "felixplatforms.com"
                }
            ],
            "destination": "https://aflaundry.felixplatforms.com/:path*",
            "permanent": true
        },
        {
            "source": "/aflaundry/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "www.felixplatforms.com"
                }
            ],
            "destination": "https://aflaundry.felixplatforms.com/:path*",
            "permanent": true
        },
        {
            "source": "/admin/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "felixplatforms.com"
                }
            ],
            "destination": "https://admin.felixplatforms.com/:path*",
            "permanent": true
        },
        {
            "source": "/admin/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "www.felixplatforms.com"
                }
            ],
            "destination": "https://admin.felixplatforms.com/:path*",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "felixstore.felixplatforms.com"
                }
            ],
            "destination": "/felix-store/index.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "felixstore.felixplatforms.com"
                }
            ],
            "destination": "/felix-store/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "aflaundry.felixplatforms.com"
                }
            ],
            "destination": "/aflaundry/index.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "aflaundry.felixplatforms.com"
                }
            ],
            "destination": "/aflaundry/:path*"
        }
    ]
}