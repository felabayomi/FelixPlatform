{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "rewrites": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "felixstore.felixplatforms.com"
                }
            ],
            "destination": "/felix-store/index.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "felixstore.felixplatforms.com"
                }
            ],
            "destination": "/felix-store/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "aflaundry.felixplatforms.com"
                }
            ],
            "destination": "/aflaundry/index.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "aflaundry.felixplatforms.com"
                }
            ],
            "destination": "/aflaundry/:path*"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "admin.felixplatforms.com"
                }
            ],
            "destination": "/admin/index.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "admin.felixplatforms.com"
                }
            ],
            "destination": "/admin/:path*"
        }
    ]
}